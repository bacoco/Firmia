# API Credentials
INSEE_CLIENT_ID=your_insee_client_id
INSEE_CLIENT_SECRET=your_insee_client_secret
INPI_USERNAME=your_inpi_username
INPI_PASSWORD=your_inpi_password
API_ENTREPRISE_TOKEN=your_api_entreprise_token
DGFIP_CLIENT_ID=your_dgfip_client_id
DGFIP_CLIENT_SECRET=your_dgfip_client_secret

# Infrastructure
REDIS_URL=redis://localhost:6379/0
DUCKDB_PATH=/data/analytics.db
AWS_REGION=eu-west-1
AWS_SECRETS_PREFIX=fci-mcp/

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8789

# Monitoring
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100